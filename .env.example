# 项目路径配置 — 合作者可按需修改
#
# 使用方式:
#   cp .env.example .env  &&  编辑 .env 中的路径
#
# Agent 技能文件 (skills/experiment_log.md 等) 引用这些变量，
# 运行时 Agent 自动读取 .env 获取实际路径。

# 实验数据根目录（存放 experiment_data/expX_*/results.csv 等）
EXPERIMENT_DATA_DIR=experiment_data

# 实验记录文档目录（存放 docs/experiments/*.md 及索引 README.md）
EXPERIMENT_DOCS_DIR=docs/experiments
